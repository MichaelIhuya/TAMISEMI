// ===================== KOBO FETCH =====================
async function fetchKobo() {
  const token = document.getElementById('koboToken').value.trim();
  const asset = document.getElementById('koboAsset').value.trim();
  const server = document.getElementById('koboServer').value.trim().replace(/\/$/, '');
  const badge = document.getElementById('koboBadge');

  if (!token || !asset) {
    badge.className='kobo-badge kobo-err';
    badge.textContent='⚠ Token/Asset missing';
    return;
  }

  badge.className='kobo-badge kobo-loading';
  badge.innerHTML='<span class="spin">⟳</span> Fetching…';

  const url = `${server}/api/v2/assets/${asset}/data/?format=json&limit=5000`;

  try {
    const res = await fetch(url, {
      headers: {
        'Authorization': `Token ${token}`,
        'Accept': 'application/json'
      }
    });

    if (!res.ok) throw new Error(`HTTP ${res.status}: ${res.statusText}`);
    const json = await res.json();
    const results = json.results || [];

    if (results.length === 0) {
      badge.className='kobo-badge kobo-err';
      badge.textContent='⚠ No submissions found';
      return;
    }

    // Map KoboToolbox submissions to council data format
    // Find field names dynamically
    const sample = results[0];
    const keys = Object.keys(sample);
    const regionKey = keys.find(k=>k.toLowerCase().includes('region')) || KOBO_FIELD_REGION;
    const statusKey = keys.find(k=>k.toLowerCase().includes('status')||k.toLowerCase().includes('submitted')) || KOBO_FIELD_STATUS;
    const councilKey = keys.find(k=>k.toLowerCase().includes('council')||k.toLowerCase().includes('district')) || 'council';

    // Build updated data: start from base, override matching records
    const updated = [...BASE_DATA];
    results.forEach(row => {
      const koboRegion = String(row[regionKey]||'').trim();
      const koboCouncil = String(row[councilKey]||'').trim();
      const rawStatus = String(row[statusKey]||'').toUpperCase().trim();
      const koboStatus = rawStatus.includes('NOT')||rawStatus==='0'||rawStatus==='NO' ? 'NOT SUBMITTED' : 'SUBMITTED';

      const idx = updated.findIndex(d =>
        d.region.toLowerCase()===koboRegion.toLowerCase() ||
        d.council.toLowerCase()===koboCouncil.toLowerCase()
      );
      if (idx !== -1) updated[idx] = {...updated[idx], status: koboStatus};
    });

    QUARTER_DATA[activeQ] = updated;
    render(updated);

    badge.className='kobo-badge kobo-ok';
    badge.textContent=`✅ ${results.length} records synced`;
    document.getElementById('koboLastSync').textContent=
      'Last: '+new Date().toLocaleTimeString('en-TZ',{timeZone:'Africa/Dar_es_Salaam'});

  } catch(err) {
    badge.className='kobo-badge kobo-err';
    badge.textContent='✕ '+err.message.substring(0,40);
    console.error('KoboToolbox fetch error:', err);

    // If CORS error, show guidance
    if(err.message.includes('fetch')||err.name==='TypeError'){
      badge.textContent='⚠ CORS error — enable API access in KoboToolbox project settings';
    }
  }
}

// ===================== FILE UPLOAD =====================
function handleFile(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const wb = XLSX.read(new Uint8Array(e.target.result), {type:'array'});
      const sheetName = wb.SheetNames.find(n=>n.toLowerCase().includes('council')) || wb.SheetNames[0];
      const raw = XLSX.utils.sheet_to_json(wb.Sheets[sheetName], {header:1, defval:''});
      let hRow = -1;
      for(let i=0;i<raw.length;i++){
        const r=raw[i].map(c=>String(c).toLowerCase());
        if(r.includes('region')&&r.includes('status')){hRow=i;break;}
      }
      if(hRow===-1){alert('Cannot find header row');return;}
      const h=raw[hRow].map(c=>String(c).toLowerCase().trim());
      const rI=h.indexOf('region'),cI=h.indexOf('council'),tI=h.indexOf('type'),sI=h.indexOf('status');
      const newData=[];
      for(let i=hRow+1;i<raw.length;i++){
        const row=raw[i];
        const region=String(row[rI]||'').trim();
        const council=String(row[cI]||'').trim();
        const type=String(row[tI]||'').trim();
        const status=String(row[sI]||'').trim().toUpperCase();
        if(region&&council&&(status==='SUBMITTED'||status==='NOT SUBMITTED'))
          newData.push({region,council,type,status});
      }
      if(newData.length===0){alert('No valid rows found');return;}
      QUARTER_DATA[activeQ]=newData;
      render(newData);
      const btn=document.querySelector('.btn-outline');
      const o=btn.textContent;
      btn.textContent=`✅ ${newData.length} rows`;
      setTimeout(()=>btn.textContent=o,2500);
    } catch(err){alert('Error: '+err.message);}
  };
  reader.readAsArrayBuffer(file);
  event.target.value='';
}

// ===================== AUTO-SYNC EVERY 5 MINUTES =====================
setInterval(()=>{
  const token=document.getElementById('koboToken').value.trim();
  if(token&&token.length>20) fetchKobo();
},5*60*1000);

// ===================== INIT =====================
render(QUARTER_DATA.Q1);
</script>

