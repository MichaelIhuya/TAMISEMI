function color(sub, tot) {
  if (tot===0) return '#374151';
  const p = sub/tot;
  if (p===1) return '#16a34a';
  if (p>=0.5) return '#d97706';
  if (p>0) return '#ea580c';
  return '#dc2626';
}
function colorFill(sub,tot){
  if(tot===0) return '#374151';
  const p=sub/tot;
  if(p===1) return '#166534';
  if(p>=0.5) return '#92400e';
  if(p>0) return '#7c2d12';
  return '#7f1d1d';
