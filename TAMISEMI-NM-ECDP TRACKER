  const pending  = users.filter(u=>u.status==='pending');
  const approved = users.filter(u=>u.status==='approved');
  const rejected = users.filter(u=>u.status==='rejected');

  // Badge on button
  const adminBtn=document.getElementById('adminBtn');
  if(adminBtn) adminBtn.innerHTML = pending.length>0
    ? '👑 Admin <span style="background:#dc2626;color:white;border-radius:10px;padding:1px 6px;font-size:10px">'+pending.length+'</span>'
    : '👑 Admin';

  // Stats row in panel
  const statEl=document.getElementById('adminStats');
  if(statEl) statEl.innerHTML=`
    <div class="admin-stat"><span class="admin-stat-val" style="color:#fbbf24">${pending.length}</span><span class="admin-stat-lbl">Pending</span></div>
    <div class="admin-stat"><span class="admin-stat-val" style="color:#4ade80">${approved.length}</span><span class="admin-stat-lbl">Approved</span></div>
    <div class="admin-stat"><span class="admin-stat-val" style="color:#f87171">${rejected.length}</span><span class="admin-stat-lbl">Rejected</span></div>
    <div class="admin-stat"><span class="admin-stat-val" style="color:#38bdf8">${users.length}</span><span class="admin-stat-lbl">Total</span></div>`;

  function card(u) {
    const ini = ((u.firstName||'?')[0]+(u.lastName||'?')[0]).toUpperCase();
    const iA  = u.role==='admin';
    const sc  = iA ? 'st-admin' : ({pending:'st-pending',approved:'st-approved',rejected:'st-rejected'}[u.status]||'st-pending');
    const sl  = iA ? '👑 Admin' : ({pending:'⏳ Pending',approved:'✅ Approved',rejected:'✕ Rejected'}[u.status]||u.status);
    const dt  = new Date(u.createdAt).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'});
    return `<div class="user-row" id="urow-${u.id}">
      <div class="user-avatar">${ini}</div>
      <div class="user-info">
        <div class="user-name">${u.firstName} ${u.lastName}</div>
        <div class="user-email">${u.email}</div>
        <div class="user-meta">${u.org||'—'} &nbsp;·&nbsp; ${dt}</div>
      </div>
      <span class="user-status ${sc}">${sl}</span>
      <div class="user-actions">
        ${u.status==='pending'  ? `<button class="ua-btn ua-approve" onclick="approveUser('${u.id}')">✓ Approve</button>
          <button class="ua-btn ua-reject" onclick="rejectUser('${u.id}')">✕ Reject</button>` : ''}
        ${u.status==='rejected' ? `<button class="ua-btn ua-approve" onclick="approveUser('${u.id}')">↩ Re-approve</button>` : ''}
        ${!iA ? `<button class="ua-btn ua-delete" onclick="deleteUser('${u.id}')">🗑</button>` : ''}
      </div></div>`;
  }

  const set=(id,arr,empty)=>{ const el=document.getElementById(id); if(el) el.innerHTML=arr.length?arr.map(card).join(''):`<div class="empty-state">${empty}</div>`; };
  set('pendingUsers',  pending,  '✅ No pending requests');
  set('approvedUsers', approved, 'No approved users yet');
  set('rejectedUsers', rejected, 'No rejected users');
}

function approveUser(id) {
  const users=DB.getUsers();
  const idx=users.findIndex(u=>u.id===id);
  if(idx===-1) return;
  users[idx].status='approved';
  users[idx].approvedAt=new Date().toISOString();
  DB.saveUsers(users);
  const row=document.getElementById('urow-'+id);
  if(row){ row.style.borderColor='#16a34a'; row.style.background='rgba(22,163,74,0.08)'; }
  setTimeout(()=>renderAdminPanel(), 700);
  showAdminToast('✅ '+users[idx].firstName+' '+users[idx].lastName+' has been approved.', 'ok');
}

function rejectUser(id) {
  if (!confirm('Reject this access request? The user will be notified.')) return;
  const users = DB.getUsers();
  const idx   = users.findIndex(u => u.id === id);
  if (idx === -1) return;
  users[idx].status = 'rejected';
  DB.saveUsers(users);
  renderAdminPanel();
  showAdminToast('Request from ' + users[idx].firstName + ' ' + users[idx].lastName + ' has been rejected.', 'warn');
}

function deleteUser(id) {
  if (!confirm('Permanently delete this user account? This cannot be undone.')) return;
  DB.saveUsers(DB.getUsers().filter(u => u.id !== id));
  renderAdminPanel();
  showAdminToast('User account deleted.', 'warn');
}

// Init EmailJS status badge on load
document.addEventListener('DOMContentLoaded', updateEjsStatus);
</script>
</body>
</html>
