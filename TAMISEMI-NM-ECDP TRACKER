function project(lng, lat) {
  const minLng=29.3, maxLng=40.5, minLat=-11.8, maxLat=-0.9;
  const W=520, H=640, pad=22;
  const x = pad + (lng - minLng) / (maxLng - minLng) * (W - pad*2);
  const y = pad + (lat - maxLat) / (minLat - maxLat) * (H - pad*2);
  return [Math.round(x*10)/10, Math.round(y*10)/10];
}

function poly(coords) {
  return coords.map(([lng,lat]) => project(lng,lat).join(',')).join(' ');
}

