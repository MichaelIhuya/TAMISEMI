<!-- MAIN -->
<div class="main">

  <!-- LEFT -->
  <div class="left">

    <!-- Overview ring -->
    <div class="overview-card">
      <div class="ring-wrap">
        <svg width="92" height="92" viewBox="0 0 92 92">
          <circle cx="46" cy="46" r="38" fill="none" stroke="#1d2d42" stroke-width="9"/>
