<body>

<!-- =================== AUTH OVERLAY =================== -->
<div id="authOverlay">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">🏛️</div>
      <h2>TAMISEMI – NMECD Tracker</h2>
      <p>ECD Report Submission System · Tanzania Mainland</p>
    </div>
    <div class="auth-tabs">
      <button class="auth-tab active" id="tabLogin" onclick="switchTab('login')">Sign In</button>
      <button class="auth-tab" id="tabRegister" onclick="switchTab('register')">Request Access</button>
    </div>
    <div class="auth-body">

      <!-- LOGIN PANEL -->
      <div class="auth-panel show" id="panelLogin">
        <div class="field">
          <label>Email Address</label>
          <input type="email" id="loginEmail" placeholder="your@email.com" onkeydown="if(event.key==='Enter')doLogin()">
        </div>
        <div class="field">
          <label>Password</label>
          <div class="pw-wrap">
            <input type="password" id="loginPw" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()">
            <button class="pw-eye" onclick="togglePw('loginPw',this)">👁</button>
          </div>
        </div>
        <button class="auth-btn auth-btn-primary" onclick="doLogin()" id="loginBtn">Sign In →</button>
        <div class="auth-msg" id="loginMsg"></div>
        <div class="divider">or</div>
        <p style="text-align:center;font-size:12px;color:#7a9bb5">Don't have access? <a href="#" onclick="switchTab('register');return false" style="color:#38bdf8;text-decoration:none">Request an account</a></p>
      </div>

      <!-- REGISTER PANEL -->
      <div class="auth-panel" id="panelRegister">
        <div class="field-row">
          <div class="field">
            <label>First Name</label>
            <input type="text" id="regFirst" placeholder="Juma">
          </div>
          <div class="field">
            <label>Last Name</label>
            <input type="text" id="regLast" placeholder="Mwangi">
          </div>
        </div>
        <div class="field">
          <label>Email Address</label>
          <input type="email" id="regEmail" placeholder="your@organization.or.tz">
        </div>
        <div class="field">
          <label>Organization / Role</label>
          <input type="text" id="regOrg" placeholder="TAMISEMI Regional Office, Arusha">
        </div>
        <div class="field">
          <label>Password</label>
          <div class="pw-wrap">
            <input type="password" id="regPw" placeholder="Min. 8 characters" oninput="checkStrength(this.value)">
            <button class="pw-eye" onclick="togglePw('regPw',this)">👁</button>
          </div>
          <div class="strength-bar" id="strengthBar"></div>
        </div>
        <div class="field">
          <label>Confirm Password</label>
          <input type="password" id="regPw2" placeholder="Repeat password">
        </div>
        <button class="auth-btn auth-btn-primary" onclick="doRegister()" id="registerBtn">Submit Access Request →</button>
        <div class="auth-msg" id="registerMsg"></div>
      </div>

      <!-- PENDING PANEL -->
      <div class="auth-panel" id="panelPending">
        <div class="pending-msg">
          <div class="pending-icon">⏳</div>
          <h3>Access Pending Approval</h3>
          <p>Your account request has been submitted.<br>
          The system administrator (<strong style="color:#38bdf8"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="8ce5e4f9f5ede1e5efe4ede9e0ccf8e9efe8e9e2a2e3fea2f8f6">[email&#160;protected]</a></strong>) has been notified and will review your request.<br><br>
          You will be able to sign in once your account is approved.</p>
          <button class="auth-btn auth-btn-primary" style="margin-top:20px" onclick="switchTab('login')">Back to Sign In</button>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- =================== ADMIN PANEL =================== -->
<div id="adminPanel">
  <div class="admin-card">

    <!-- Header -->
    <div class="admin-hdr">
      <div style="display:flex;align-items:center;gap:10px">
        <span style="font-size:18px">👑</span>
        <div>
          <div style="font-size:15px;font-weight:600">Admin Panel</div>
          <div style="font-size:11px;color:#7a9bb5">TAMISEMI NMECD Dashboard</div>
        </div>
      </div>
      <button class="admin-close" onclick="closeAdmin()">✕</button>
    </div>

    <!-- Tabs -->
    <div style="display:flex;border-bottom:1px solid #1e3a5c;background:#0a1e35">
      <button class="admin-tab active" id="atab-users"  onclick="switchAdminTab('users')" >👥 User Requests</button>
      <button class="admin-tab"        id="atab-email"  onclick="switchAdminTab('email')" >📧 Email Setup</button>
      <button class="admin-tab"        id="atab-guide"  onclick="switchAdminTab('guide')" >📖 How It Works</button>
    </div>

    <!-- Toast -->
    <div id="adminToast" class="admin-toast"></div>

    <!-- ── TAB: USERS ── -->
    <div class="admin-body admin-tab-panel" id="apanel-users">
      <div id="adminStats" class="admin-stats"></div>

      <div class="admin-section-title">⏳ Pending Approval</div>
      <div id="pendingUsers"></div>

      <div style="margin:20px 0 12px;border-top:1px solid #1e3a5c;padding-top:20px">
        <div class="admin-section-title">✅ Approved Users</div>
      </div>
      <div id="approvedUsers"></div>

      <div style="margin:20px 0 12px;border-top:1px solid #1e3a5c;padding-top:20px">
        <div class="admin-section-title">✕ Rejected</div>
      </div>
      <div id="rejectedUsers"></div>
    </div>

    <!-- ── TAB: EMAIL SETUP ── -->
    <div class="admin-body admin-tab-panel" id="apanel-email" style="display:none">

      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
        <div>
          <div style="font-size:14px;font-weight:600;margin-bottom:3px">EmailJS Notification Settings</div>
          <div style="font-size:12px;color:#7a9bb5">Configure so you receive emails when users request access</div>
        </div>
        <span class="kobo-badge kobo-loading" id="ejsStatusBadge">⚠ Not configured</span>
      </div>

      <!-- Status box -->
      <div id="ejsStatusBox" style="background:#0a1e35;border:1px solid #1e3a5c;border-radius:10px;padding:14px;margin-bottom:18px;font-size:12px;line-height:1.8;color:#7a9bb5">
        Loading status…
      </div>

      <!-- How it works info -->
      <div style="background:#0a1e35;border:1px solid #1e3a5c;border-radius:10px;padding:16px;margin-bottom:18px">
        <div style="font-size:12px;font-weight:600;color:#38bdf8;margin-bottom:8px">ℹ How it works — one template only</div>
        <div style="font-size:12px;color:#7a9bb5;line-height:1.9">
          When a user registers, they receive an <strong style="color:#f0f6ff">activation link</strong> in their own email.<br>
          Clicking it instantly activates their account. You only need <strong style="color:#f0f6ff">one template</strong>.
        </div>
      </div>

      <div class="ejs-field">
        <label>① Public Key</label>
        <input id="ejsPublicKey" placeholder="e.g. aBcDeFgHiJkLmNoPqRsT" autocomplete="off">
        <div class="hint">emailjs.com → Account → API Keys → <strong style="color:#f0f6ff">Public Key</strong></div>
      </div>
      <div class="ejs-field">
        <label>② Service ID</label>
        <input id="ejsServiceId" placeholder="e.g. service_abc12345">
        <div class="hint">emailjs.com → Email Services → your Gmail/Outlook → <strong style="color:#f0f6ff">Service ID</strong></div>
      </div>
      <div class="ejs-field">
        <label>③ Template ID — Activation Email</label>
        <input id="ejsTmplActivation" placeholder="e.g. template_activate">
        <div class="hint">emailjs.com → Email Templates → your template → <strong style="color:#f0f6ff">Template ID</strong></div>
      </div>

      <!-- Ready-to-copy template -->
      <div style="background:#0a1e35;border:1px solid #1e3a5c;border-radius:10px;padding:14px;margin-bottom:18px">
        <div style="font-size:11px;font-weight:600;color:#f0f6ff;margin-bottom:10px">📋 Set up your EmailJS template exactly like this:</div>
        <div style="display:grid;grid-template-columns:90px 1fr;gap:6px 12px;font-size:11px;margin-bottom:12px">
          <span style="color:#7a9bb5;line-height:26px">To Email:</span>
          <code style="background:#162032;color:#38bdf8;padding:4px 9px;border-radius:5px;display:block">{{to_email}}</code>
          <span style="color:#7a9bb5;line-height:26px">To Name:</span>
          <code style="background:#162032;color:#38bdf8;padding:4px 9px;border-radius:5px;display:block">{{to_name}}</code>
          <span style="color:#7a9bb5;line-height:26px">Subject:</span>
          <code style="background:#162032;color:#38bdf8;padding:4px 9px;border-radius:5px;display:block">Activate Your TAMISEMI Dashboard Account</code>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
          <div style="font-size:11px;color:#7a9bb5">Message / Content — paste this HTML into the template body:</div>
          <button onclick="copyTemplate()" style="background:#1e40af;color:white;border:none;border-radius:6px;padding:4px 10px;font-size:10px;cursor:pointer;font-family:'DM Sans',sans-serif">📋 Copy</button>
        </div>
        <div id="templateBody" style="background:#162032;border-radius:7px;padding:12px;font-family:'DM Mono',monospace;font-size:10.5px;color:#94a3b8;line-height:1.7;white-space:pre-wrap;max-height:220px;overflow-y:auto;user-select:all">&lt;div style="font-family:Arial,sans-serif;max-width:520px;margin:0 auto;padding:24px;background:#f9f9f9;border-radius:8px"&gt;
  &lt;div style="background:#16a34a;padding:16px 24px;border-radius:6px 6px 0 0"&gt;
    &lt;h2 style="color:white;margin:0;font-size:18px"&gt;TAMISEMI NMECD Dashboard&lt;/h2&gt;
    &lt;p style="color:#dcfce7;margin:4px 0 0;font-size:12px"&gt;Early Childhood Development &amp;middot; Tanzania Mainland&lt;/p&gt;
  &lt;/div&gt;
  &lt;div style="background:white;padding:24px;border-radius:0 0 6px 6px;border:1px solid #e5e7eb"&gt;
    &lt;p style="font-size:15px;color:#111"&gt;Dear &lt;strong&gt;{{to_name}}&lt;/strong&gt;,&lt;/p&gt;
    &lt;p style="color:#374151;line-height:1.7"&gt;
      Your account request for the TAMISEMI NMECD Dashboard has been received.
      Click the button below to activate your account and sign in.
    &lt;/p&gt;
    &lt;div style="text-align:center;margin:28px 0"&gt;
      &lt;a href="{{activation_link}}"
         style="background:#16a34a;color:white;padding:14px 36px;border-radius:8px;
                text-decoration:none;font-size:15px;font-weight:bold;display:inline-block"&gt;
        ✅ Click Here to Activate Account
      &lt;/a&gt;
    &lt;/div&gt;
    &lt;p style="color:#6b7280;font-size:12px;line-height:1.6"&gt;
      After clicking, sign in using:&lt;br&gt;
      &lt;strong&gt;Email:&lt;/strong&gt; {{to_email}}&lt;br&gt;
      &lt;strong&gt;Password:&lt;/strong&gt; the password you chose when registering
    &lt;/p&gt;
    &lt;hr style="border:none;border-top:1px solid #e5e7eb;margin:20px 0"&gt;
    &lt;p style="color:#9ca3af;font-size:11px"&gt;If you did not request this account, ignore this email.&lt;/p&gt;
  &lt;/div&gt;
&lt;/div&gt;</div>
        <div style="font-size:10px;color:#4a6a8a;margin-top:8px">💡 In EmailJS, make sure the template editor is set to <strong style="color:#f0f6ff">HTML mode</strong> (not plain text) so the button renders correctly.</div>
      </div>

      <div class="auth-msg" id="ejsMsg" style="display:none;margin-bottom:12px"></div>

      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="ejs-btn ejs-save" onclick="saveEjsConfig()">💾 Save Configuration</button>
        <button class="ejs-btn ejs-test" id="ejsTestBtn" onclick="testEmailJs()">📨 Send Test Email to <a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="f990918c809894909a91989c95b98d9c9a9d9c97d7968bd78d83">[email&#160;protected]</a></button>
      </div>
    </div>

    <!-- ── TAB: HOW IT WORKS ── -->
    <div class="admin-body admin-tab-panel" id="apanel-guide" style="display:none">
      <div style="font-size:14px;font-weight:600;margin-bottom:14px;color:#f0f6ff">📖 How the User Management System Works</div>

      <div class="guide-step">
        <div class="guide-num">1</div>
        <div>
          <strong style="color:#f0f6ff">New user requests access</strong><br>
          They click "Request Access" on the login screen, fill in their name, email, organization and password. Their account is saved on their computer as <span style="color:#fbbf24;background:rgba(245,158,11,0.1);padding:1px 6px;border-radius:4px">Pending</span>.
        </div>
      </div>
      <div class="guide-step">
        <div class="guide-num">2</div>
        <div>
          <strong style="color:#f0f6ff">You receive an email notification</strong><br>
          An email is sent to <span style="color:#38bdf8"><a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="dab3b2afa3bbb7b3b9b2bbbfb69aaebfb9bebfb4f4b5a8f4aea0">[email&#160;protected]</a></span> with the user's details and two buttons: <span style="color:#4ade80">✓ Approve</span> and <span style="color:#f87171">✕ Reject</span>. <em style="color:#7a9bb5">(Requires EmailJS to be configured in the Email Setup tab)</em>
        </div>
      </div>
      <div class="guide-step">
        <div class="guide-num">3</div>
        <div>
          <strong style="color:#f0f6ff">You approve from email or Admin Panel</strong><br>
          Click Approve in the email → your dashboard opens and automatically processes the approval. Or open the Admin Panel → Users tab → click ✓ Approve next to any pending request.
        </div>
      </div>
      <div class="guide-step">
        <div class="guide-num">4</div>
        <div>
          <strong style="color:#f0f6ff">User receives approval email</strong><br>
          An automatic email is sent to the new user telling them their account is approved and they can now sign in.
        </div>
      </div>
      <div class="guide-step">
        <div class="guide-num">5</div>
        <div>
          <strong style="color:#f0f6ff">User signs in and accesses the dashboard</strong><br>
          On their own computer they reload the dashboard and sign in. They can view all submission data but cannot access Admin Panel features.
        </div>
      </div>

      <div style="background:#0a1e35;border:1px solid #1e3a5c;border-radius:10px;padding:14px;margin-top:18px;font-size:12px;color:#7a9bb5;line-height:1.8">
        <strong style="color:#fbbf24">⚠ Important:</strong> This is a local HTML file — user accounts are stored in each person's browser. The EmailJS emails are the bridge between computers. Without EmailJS configured, you can still manually approve users if they are on the same computer, but you won't receive email notifications.
      </div>
    </div>

  </div>
</div>

<!-- TOPBAR -->
