  const search = document.getElementById('searchIn').value.toLowerCase();
  let rows = Object.entries(sm).sort(([,a],[,b])=>b.submitted/b.total-a.submitted/a.total);
  if (search) rows = rows.filter(([r])=>r.toLowerCase().includes(search));
  if (activeFilt==='full') rows = rows.filter(([,v])=>v.submitted===v.total);
  if (activeFilt==='partial') rows = rows.filter(([,v])=>v.submitted>0&&v.submitted<v.total);
  if (activeFilt==='none') rows = rows.filter(([,v])=>v.submitted===0);

  document.getElementById('tBody').innerHTML = rows.map(([r,v])=>{
    const p = Math.round(v.submitted/v.total*100);
