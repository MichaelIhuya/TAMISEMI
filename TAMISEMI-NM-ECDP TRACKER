// ══════════ LOGIN ══════════
async function doLogin() {
  const emailVal = (document.getElementById('loginEmail').value||'').trim().toLowerCase();
  const pwVal    = (document.getElementById('loginPw').value||'');
  const btn      = document.getElementById('loginBtn');
  if (!emailVal||!pwVal) { showMsg('loginMsg','Please enter your email and password.','err'); return; }
  btn.disabled=true; btn.textContent='Verifying…';
  try {
    const hash  = await hashPw(pwVal);
    const users = DB.getUsers();
    const user  = users.find(u => u.email === emailVal);
    if (!user)                      { showMsg('loginMsg','No account found with that email address.','err'); return; }
    if (user.passwordHash !== hash) { showMsg('loginMsg','Incorrect password. Please try again.','err'); return; }
    if (user.status==='pending')    { showMsg('loginMsg','Your account is awaiting admin approval. Please check back later.','info'); return; }
    if (user.status==='rejected')   { showMsg('loginMsg','Access was not granted. Contact '+ADMIN_EMAIL+' for help.','err'); return; }
    loginSuccess(user, true);
  } catch(err) {
    showMsg('loginMsg','An error occurred. Please try again.','err');
  } finally {
    btn.disabled=false; btn.textContent='Sign In →';
  }
}

// ══════════ LOGIN SUCCESS ══════════
function loginSuccess(user, doSave) {
  if (doSave) DB.saveSession({ userId:user.id, loginAt:new Date().toISOString() });
  const overlay = document.getElementById('authOverlay');
  if (overlay) overlay.style.display = 'none';

  const ini = ((user.firstName||'?')[0]+(user.lastName||'?')[0]).toUpperCase();
  const el  = id => document.getElementById(id);
  if(el('ucAvatar'))  el('ucAvatar').textContent  = ini;
  if(el('ucName'))    el('ucName').textContent    = user.firstName+' '+user.lastName;
  if(el('ucRole'))    el('ucRole').textContent    = user.role==='admin' ? 'Administrator' : (user.org||'').split(',')[0]||'Viewer';
  if(el('userChip'))  el('userChip').style.display  = 'flex';
  if(el('logoutBtn')) el('logoutBtn').style.display = 'inline-flex';
  if(el('adminBtn'))  el('adminBtn').style.display  = user.role==='admin' ? 'inline-flex' : 'none';
  if(user.role==='admin') updateEjsStatus();

  // Check if we just processed an activation link from email
  const done = sessionStorage.getItem('tam_action_done');
  if (done) {
    sessionStorage.removeItem('tam_action_done');
    const parts = done.split(':');
    const act   = parts[0];
    if (act === 'activated') {
      // User just activated via their email link — show welcome message
      setTimeout(() => showAdminToast('🎉 Account activated! You are now signed in.', 'ok'), 400);
    }
  }

  if (user.role === 'admin') {
    const pending = DB.getUsers().filter(u => u.status === 'pending');
    if (pending.length > 0 && doSave) setTimeout(() => openAdmin(), 700);
  }
}

// ══════════ REGISTER ══════════
async function doRegister() {
  const g    = id => (document.getElementById(id)||{value:''}).value||'';
  const first= g('regFirst').trim(), last=g('regLast').trim();
  const email= g('regEmail').trim().toLowerCase(), org=g('regOrg').trim();
  const pw   = g('regPw'), pw2=g('regPw2');
  const btn  = document.getElementById('registerBtn');

  if (!first||!last||!email||!org||!pw||!pw2)  { showMsg('registerMsg','Please fill in all fields.','err'); return; }
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showMsg('registerMsg','Please enter a valid email address.','err'); return; }
  if (pw.length<8)  { showMsg('registerMsg','Password must be at least 8 characters.','err'); return; }
  if (pw!==pw2)     { showMsg('registerMsg','Passwords do not match.','err'); return; }

  const users = DB.getUsers();
  if (users.find(u=>u.email===email)) { showMsg('registerMsg','An account with this email already exists.','err'); return; }

  btn.disabled=true; btn.textContent='Submitting…';
  try {
    const hash    = await hashPw(pw);
    const newUser = {
      id:'usr-'+Date.now(), firstName:first, lastName:last,
      email, org, role:'viewer', status:'pending',
      passwordHash:hash, createdAt:new Date().toISOString(),
    };
    users.push(newUser);
    DB.saveUsers(users);

    // Send activation email directly to the new user
    const emailResult = await sendActivationEmail(newUser);

    // Show result to user
    document.querySelectorAll('.auth-tab').forEach(t => t.style.display='none');
    const pp = document.getElementById('panelPending');
    const emailNote = emailResult.ok
      ? `<span style="color:#4ade80">✅ An activation link has been sent to <strong>${email}</strong>. Click it to activate your account.</span>`
      : `<span style="color:#fbbf24">⚠ Activation email could not be sent. Please contact <strong>${ADMIN_EMAIL}</strong> to request manual activation.</span>`;
    if (pp) pp.querySelector('.pending-msg').innerHTML = `
      <div class="pending-icon">📩</div>
      <h3>Check Your Email!</h3>
      <p>Welcome, <strong style="color:#f0f6ff">${first}</strong>.<br><br>
      ${emailNote}<br><br>
      Once you click the activation link, come back here and sign in with:<br>
      <strong style="color:#38bdf8">${email}</strong></p>
      <button class="auth-btn auth-btn-primary" style="margin-top:20px;max-width:200px;margin-left:auto;margin-right:auto"
        onclick="resetToLogin()">← Back to Sign In</button>`;
    ['panelLogin','panelRegister'].forEach(id=>{ const e=document.getElementById(id); if(e) e.classList.remove('show'); });
    if (pp) pp.classList.add('show');

  } catch(err) {
    showMsg('registerMsg','Registration failed: '+err.message,'err');
  } finally {
    btn.disabled=false; btn.textContent='Submit Access Request →';
  }
}

function resetToLogin() {
  document.querySelectorAll('.auth-tab').forEach(t => t.style.display='');
  switchTab('login');
}

function copyTemplate() {
  const el = document.getElementById('templateBody');
