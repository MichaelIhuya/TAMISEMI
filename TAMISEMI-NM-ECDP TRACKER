        </svg>
        <div class="ring-center">
          <div class="ring-pct" id="ringPct">0%</div>
          <div class="ring-sub">overall</div>
        </div>
      </div>
      <div class="overview-info">
        <h3 id="ovTitle">Submission Progress</h3>
        <p id="ovDesc" style="color:var(--muted);font-size:12px">Loading data…</p>
