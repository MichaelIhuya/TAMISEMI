<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TAMISEMI – NMECD Report Submission Tracker</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --green:#16a34a; --green-mid:#22c55e; --green-light:#dcfce7;
  --red:#dc2626; --red-light:#fef2f2;
  --amber:#d97706; --amber-light:#fef3c7;
  --blue:#1d4ed8; --accent:#38bdf8;
  --bg:#0c1525; --surface:#162032; --surface2:#1d2d42;
  --border:#243348; --text:#f0f6ff; --muted:#7a9bb5;
  --q1:#6366f1; --q2:#0ea5e9; --q3:#f59e0b; --q4:#10b981;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}

/* TOPBAR */
.topbar{
  background:linear-gradient(135deg,#0c1525,#162d45,#0c1525);
  border-bottom:1px solid var(--border);
  padding:14px 28px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:200;
  box-shadow:0 2px 20px rgba(0,0,0,0.4);
}
.logo-wrap{display:flex;align-items:center;gap:12px}
.logo{width:38px;height:38px;background:linear-gradient(135deg,#16a34a,#0d9488);
  border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px}
.brand h1{font-size:14px;font-weight:600;line-height:1.2}
.brand p{font-size:11px;color:var(--muted)}
.topbar-right{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.live-badge{display:flex;align-items:center;gap:5px;font-size:11px;color:#4ade80;
  background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);
  padding:4px 10px;border-radius:20px}
.live-dot{width:7px;height:7px;border-radius:50%;background:#4ade80;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.8)}}
.btn{display:inline-flex;align-items:center;gap:5px;font-family:'DM Sans',sans-serif;
  font-size:12px;font-weight:500;padding:7px 14px;border-radius:8px;border:none;
  cursor:pointer;transition:all 0.15s}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--muted)}
.btn-outline:hover{border-color:var(--accent);color:var(--accent)}
.btn-green{background:var(--green);color:white}
.btn-green:hover{background:#15803d}
.btn-blue{background:#1e40af;color:white}
.btn-blue:hover{background:#1d4ed8}
#fileInput{display:none}

/* QUARTER SELECTOR */
.quarter-bar{
  background:var(--surface);border-bottom:1px solid var(--border);
  padding:10px 28px;display:flex;align-items:center;gap:16px;flex-wrap:wrap
}
.quarter-label{font-size:12px;color:var(--muted);font-weight:500;white-space:nowrap}
.quarter-tabs{display:flex;gap:4px}
.qtab{
  padding:7px 18px;border-radius:8px;font-size:12px;font-weight:500;
  border:1px solid var(--border);background:transparent;color:var(--muted);
  cursor:pointer;transition:all 0.15s;font-family:'DM Sans',sans-serif
}
.qtab:hover{border-color:var(--muted);color:var(--text)}
.qtab.active-q1{background:rgba(99,102,241,0.15);border-color:#6366f1;color:#a5b4fc}
.qtab.active-q2{background:rgba(14,165,233,0.15);border-color:#0ea5e9;color:#7dd3fc}
.qtab.active-q3{background:rgba(245,158,11,0.15);border-color:#f59e0b;color:#fcd34d}
.qtab.active-q4{background:rgba(16,185,129,0.15);border-color:#10b981;color:#6ee7b7}
.kobo-status{margin-left:auto;display:flex;align-items:center;gap:8px;font-size:12px}
.kobo-badge{padding:5px 12px;border-radius:20px;font-size:11px;font-weight:500;
  display:flex;align-items:center;gap:5px}
.kobo-ok{background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);color:#4ade80}
.kobo-err{background:rgba(220,38,38,0.1);border:1px solid rgba(220,38,38,0.25);color:#f87171}
.kobo-loading{background:rgba(56,189,248,0.1);border:1px solid rgba(56,189,248,0.25);color:#7dd3fc}
.spin{animation:spin 1s linear infinite;display:inline-block}
@keyframes spin{to{transform:rotate(360deg)}}

/* STATS */
.stats-row{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:1px;background:var(--border);
  border-bottom:1px solid var(--border)
}
.stat{background:var(--surface);padding:18px 24px}
.stat-lbl{font-size:10px;text-transform:uppercase;letter-spacing:0.09em;color:var(--muted);margin-bottom:5px}
.stat-val{font-size:30px;font-weight:700;font-family:'DM Mono',monospace;line-height:1}
.stat-sub{font-size:11px;color:var(--muted);margin-top:3px}
.s-blue .stat-val{color:var(--accent)}
.s-green .stat-val{color:#4ade80}
.s-red .stat-val{color:#f87171}
.s-amber .stat-val{color:#fbbf24}

/* MAIN GRID */
.main{display:grid;grid-template-columns:1fr 460px;min-height:calc(100vh - 162px)}

/* LEFT */
.left{padding:20px;overflow-y:auto;border-right:1px solid var(--border)}
.section-head{
  font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;
  color:var(--muted);margin:0 0 14px;display:flex;align-items:center;gap:8px
}
.section-head::after{content:'';flex:1;height:1px;background:var(--border)}

/* PROGRESS RING */
.overview-card{
  background:var(--surface);border:1px solid var(--border);border-radius:14px;
  padding:20px;display:flex;align-items:center;gap:24px;margin-bottom:18px
}
.ring-wrap{position:relative;width:92px;height:92px;flex-shrink:0}
.ring-wrap svg{transform:rotate(-90deg)}
.ring-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.ring-pct{font-size:20px;font-weight:700;font-family:'DM Mono',monospace;color:#4ade80}
.ring-sub{font-size:9px;color:var(--muted)}
.overview-info h3{font-size:15px;font-weight:600;margin-bottom:4px}
.overview-info p{font-size:12px;color:var(--muted);line-height:1.6}
.spark{display:flex;gap:2px;margin-top:10px}
.spark-bar{height:5px;border-radius:3px;flex:1;min-width:4px}

/* TABLE */
.table-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:18px}
.table-controls{padding:10px 14px;border-bottom:1px solid var(--border);display:flex;gap:8px;flex-wrap:wrap}
.search-in{
  flex:1;min-width:120px;background:var(--bg);border:1px solid var(--border);
  color:var(--text);font-family:'DM Sans',sans-serif;font-size:12px;
  padding:7px 11px;border-radius:7px;outline:none
}
.search-in:focus{border-color:var(--accent)}
.filt{
  background:var(--bg);border:1px solid var(--border);color:var(--muted);
  font-family:'DM Sans',sans-serif;font-size:11px;padding:7px 12px;border-radius:7px;
  cursor:pointer;transition:all 0.15s
}
.filt.on{background:var(--green);border-color:var(--green);color:white}
table{width:100%;border-collapse:collapse;font-size:12px}
thead th{
  padding:9px 14px;text-align:left;font-size:10px;font-weight:600;
  text-transform:uppercase;letter-spacing:0.06em;color:var(--muted);
  background:var(--surface2);border-bottom:1px solid var(--border)
}
tbody tr{border-bottom:1px solid rgba(36,51,72,0.6);cursor:pointer;transition:background 0.12s}
tbody tr:hover{background:var(--surface2)}
tbody tr.selected{background:rgba(56,189,248,0.08);border-left:3px solid var(--accent)}
tbody td{padding:9px 14px}
.prog-wrap{display:flex;align-items:center;gap:7px}
.prog-bg{flex:1;height:4px;background:var(--bg);border-radius:2px;overflow:hidden}
.prog-fill{height:100%;border-radius:2px;transition:width 0.5s}
.pct-txt{font-size:11px;font-family:'DM Mono',monospace;color:var(--muted);min-width:34px;text-align:right}
.badge{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:12px;font-size:10px;font-weight:500}
.b-green{background:rgba(22,163,74,0.15);color:#4ade80}
.b-red{background:rgba(220,38,38,0.15);color:#f87171}
.b-amber{background:rgba(217,119,6,0.15);color:#fbbf24}

/* COUNCILS */
.council-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.council-hdr{
  padding:12px 16px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;font-size:12px;font-weight:600
}
.council-grid{display:grid;grid-template-columns:1fr 1fr;max-height:280px;overflow-y:auto}
.ci{
  padding:9px 12px;display:flex;align-items:center;gap:8px;font-size:11px;
  border-bottom:1px solid rgba(36,51,72,0.5);transition:background 0.12s
}
.ci:hover{background:var(--surface2)}
.ci-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.ci-name{flex:1;line-height:1.3}
.ci-type{font-size:10px;color:var(--muted);background:var(--bg);padding:1px 5px;border-radius:4px;margin-left:auto}

/* RIGHT / MAP */
.right{overflow-y:auto;background:var(--bg)}
.map-hdr{padding:16px 20px 12px;border-bottom:1px solid var(--border)}
.map-hdr h2{font-size:13px;font-weight:600;margin-bottom:3px}
.map-hdr p{font-size:11px;color:var(--muted)}
.map-legend{display:flex;gap:14px;margin-top:10px;flex-wrap:wrap}
.leg-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted)}
.leg-circle{width:12px;height:12px;border-radius:50%;flex-shrink:0}
.map-area{padding:10px 14px 16px;position:relative}
#tzMap{width:100%;display:block;cursor:default}
.tooltip{
  position:fixed;background:var(--surface2);border:1px solid var(--border);
  border-radius:10px;padding:10px 14px;font-size:12px;pointer-events:none;
  z-index:999;min-width:170px;display:none;
  box-shadow:0 8px 32px rgba(0,0,0,0.5)
}
.tt-region{font-size:14px;font-weight:600;margin-bottom:8px;color:var(--text)}
.tt-row{display:flex;justify-content:space-between;gap:14px;margin-bottom:3px}
.tt-lbl{color:var(--muted);font-size:11px}
.tt-val{font-weight:600;font-family:'DM Mono',monospace;font-size:12px}
.map-footer{padding:6px 14px 12px;text-align:right;font-size:10px;color:var(--muted);border-top:1px solid var(--border)}

/* Kobo config panel */
.kobo-panel{
  background:var(--surface2);border:1px solid var(--border);border-radius:12px;
  padding:14px;margin:0 28px 0;font-size:12px
}
.kobo-panel h3{font-size:12px;font-weight:600;margin-bottom:10px;color:var(--accent)}
.kobo-inputs{display:flex;gap:8px;flex-wrap:wrap}
.kobo-in{
  flex:1;min-width:180px;background:var(--bg);border:1px solid var(--border);
  color:var(--text);font-family:'DM Mono',monospace;font-size:11px;
  padding:7px 10px;border-radius:7px;outline:none
}
.kobo-in:focus{border-color:var(--accent)}

@media(max-width:1100px){
  .main{grid-template-columns:1fr}
  .stats-row{grid-template-columns:repeat(2,1fr)}
  .right{border-top:1px solid var(--border)}
}

/* =================== EMAILJS MODAL =================== */
#ejsModal{position:fixed;inset:0;z-index:9998;background:rgba(6,14,26,0.88);display:none;align-items:center;justify-content:center;padding:20px}
#ejsModal.show{display:flex}
.ejs-card{background:#111d2e;border:1px solid #1e3a5c;border-radius:18px;width:100%;max-width:520px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.6)}
.ejs-hdr{padding:18px 24px;border-bottom:1px solid #1e3a5c;background:#0a1e35;display:flex;align-items:center;justify-content:space-between}
.ejs-hdr h2{font-size:15px;font-weight:600}
.ejs-close{background:none;border:none;color:#7a9bb5;font-size:18px;cursor:pointer;padding:4px 8px;border-radius:6px}
.ejs-close:hover{color:#f87171}
.ejs-body{padding:20px 24px 24px}
.ejs-field{margin-bottom:14px}
.ejs-field label{display:block;font-size:11px;font-weight:600;color:#7a9bb5;margin-bottom:5px;text-transform:uppercase;letter-spacing:0.06em}
.ejs-field input{width:100%;background:#0c1525;border:1px solid #243348;color:#f0f6ff;font-family:'DM Mono',monospace;font-size:12px;padding:9px 12px;border-radius:8px;outline:none}
.ejs-field input:focus{border-color:#38bdf8}
.ejs-field .hint{font-size:10px;color:#4a6a8a;margin-top:4px;line-height:1.5}
.ejs-actions{display:flex;gap:8px;margin-top:18px;flex-wrap:wrap}
.ejs-btn{padding:9px 16px;border-radius:8px;font-size:12px;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;border:none;transition:all 0.15s}
.ejs-save{background:#16a34a;color:white}.ejs-save:hover{background:#15803d}
.ejs-test{background:#1e40af;color:white}.ejs-test:hover{background:#1d4ed8}
.ejs-cancel{background:transparent;border:1px solid #243348;color:#7a9bb5}.ejs-cancel:hover{border-color:#38bdf8;color:#38bdf8}
.ejs-divider{border:none;border-top:1px solid #1e3a5c;margin:16px 0}
.ejs-step{display:flex;gap:10px;margin-bottom:10px;font-size:12px;line-height:1.6;color:#7a9bb5}
.ejs-step-num{width:20px;height:20px;border-radius:50%;background:#1e3a5c;color:#38bdf8;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}

/* Admin tabs */
.admin-tab{
  flex:1;padding:12px 8px;font-size:12px;font-weight:500;
  font-family:'DM Sans',sans-serif;background:transparent;
  border:none;color:#7a9bb5;cursor:pointer;
  border-bottom:2px solid transparent;transition:all 0.15s;
}
.admin-tab:hover{color:#f0f6ff;background:rgba(255,255,255,0.03)}
.admin-tab.active{color:#38bdf8;border-bottom-color:#38bdf8;background:rgba(56,189,248,0.05)}
.admin-tab-panel{display:block}

/* Guide steps */
.guide-step{display:flex;gap:12px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #1e3a5c}
.guide-step:last-of-type{border-bottom:none}
.guide-num{
  width:26px;height:26px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,#1e40af,#0d9488);
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:700;color:white;margin-top:2px;
}

/* Admin toast */
.admin-toast{margin:12px 20px 0;padding:10px 16px;border-radius:9px;font-size:13px;display:none}
.admin-toast.ok{background:rgba(22,163,74,0.15);border:1px solid rgba(22,163,74,0.3);color:#4ade80}
.admin-toast.warn{background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.3);color:#fbbf24}
.admin-toast.err{background:rgba(220,38,38,0.12);border:1px solid rgba(220,38,38,0.25);color:#f87171}

/* Admin stats row */
.admin-stats{display:flex;gap:1px;background:#1e3a5c;border-radius:10px;overflow:hidden;margin-bottom:16px}
.admin-stat{flex:1;background:#0a1e35;padding:10px;text-align:center}
.admin-stat-val{display:block;font-size:22px;font-weight:700;font-family:'DM Mono',monospace}
.admin-stat-lbl{display:block;font-size:10px;color:#7a9bb5;text-transform:uppercase;letter-spacing:0.06em;margin-top:2px}

/* =================== AUTH OVERLAY =================== */
#authOverlay{
  position:fixed;inset:0;z-index:9999;
  background:radial-gradient(ellipse at 40% 30%,#0d2137 0%,#060e1a 70%);
  display:flex;align-items:center;justify-content:center;
  padding:20px;
}
.auth-card{
  background:#111d2e;border:1px solid #1e3a5c;border-radius:20px;
  width:100%;max-width:440px;overflow:hidden;
  box-shadow:0 30px 80px rgba(0,0,0,0.7);
}
.auth-header{
  padding:28px 32px 20px;
  background:linear-gradient(135deg,#0a1e35,#112944);
  border-bottom:1px solid #1e3a5c;
  text-align:center;
}
.auth-logo{
  width:52px;height:52px;
  background:linear-gradient(135deg,#16a34a,#0d9488);
  border-radius:14px;margin:0 auto 14px;
  display:flex;align-items:center;justify-content:center;font-size:22px;
}
.auth-header h2{font-size:17px;font-weight:600;margin-bottom:4px}
.auth-header p{font-size:12px;color:#7a9bb5}
.auth-tabs{display:flex;border-bottom:1px solid #1e3a5c}
.auth-tab{
  flex:1;padding:13px;text-align:center;font-size:13px;font-weight:500;
  color:#7a9bb5;cursor:pointer;border:none;background:transparent;
  border-bottom:2px solid transparent;transition:all 0.15s;
  font-family:'DM Sans',sans-serif;
}
.auth-tab.active{color:#38bdf8;border-bottom-color:#38bdf8;background:rgba(56,189,248,0.05)}
.auth-body{padding:24px 32px 28px}
.auth-panel{display:none}
.auth-panel.show{display:block}
.field{margin-bottom:16px}
.field label{display:block;font-size:12px;font-weight:500;color:#7a9bb5;margin-bottom:6px}
.field input,.field select{
  width:100%;background:#0c1525;border:1px solid #243348;
  color:#f0f6ff;font-family:'DM Sans',sans-serif;font-size:13px;
  padding:10px 13px;border-radius:9px;outline:none;transition:border 0.15s;
}
.field input:focus,.field select:focus{border-color:#38bdf8}
.field input::placeholder{color:#3d5a75}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.auth-btn{
  width:100%;padding:12px;border-radius:10px;border:none;
  font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;
  cursor:pointer;transition:all 0.15s;margin-top:4px;
}
.auth-btn-primary{background:linear-gradient(135deg,#16a34a,#0d9488);color:white}
.auth-btn-primary:hover{opacity:0.9;transform:translateY(-1px)}
.auth-btn-primary:disabled{opacity:0.5;cursor:not-allowed;transform:none}
.auth-msg{
  margin-top:12px;padding:10px 13px;border-radius:8px;
  font-size:12px;text-align:center;display:none;
}
.auth-msg.ok{background:rgba(22,163,74,0.15);color:#4ade80;border:1px solid rgba(22,163,74,0.25)}
.auth-msg.err{background:rgba(220,38,38,0.12);color:#f87171;border:1px solid rgba(220,38,38,0.25)}
.auth-msg.info{background:rgba(56,189,248,0.1);color:#7dd3fc;border:1px solid rgba(56,189,248,0.25)}
.divider{display:flex;align-items:center;gap:10px;margin:16px 0;color:#3d5a75;font-size:11px}
.divider::before,.divider::after{content:'';flex:1;height:1px;background:#1e3a5c}
.pw-wrap{position:relative}
.pw-wrap input{padding-right:36px}
.pw-eye{
  position:absolute;right:10px;top:50%;transform:translateY(-50%);
  background:none;border:none;color:#3d5a75;cursor:pointer;font-size:14px;padding:2px
}
.strength-bar{height:3px;border-radius:2px;margin-top:5px;transition:all 0.3s;background:#1e3a5c}
.pending-msg{
  text-align:center;padding:28px 24px;
}
.pending-icon{font-size:40px;margin-bottom:12px}
.pending-msg h3{font-size:16px;font-weight:600;margin-bottom:8px}
.pending-msg p{font-size:12px;color:#7a9bb5;line-height:1.7}

/* =================== ADMIN PANEL =================== */
#adminPanel{
  position:fixed;inset:0;z-index:8888;
  background:rgba(6,14,26,0.92);
  display:none;align-items:center;justify-content:center;padding:20px;
}
#adminPanel.show{display:flex}
.admin-card{
  background:#111d2e;border:1px solid #1e3a5c;border-radius:18px;
  width:100%;max-width:700px;max-height:85vh;overflow:hidden;
  display:flex;flex-direction:column;
  box-shadow:0 20px 60px rgba(0,0,0,0.6);
}
.admin-hdr{
  padding:18px 24px;border-bottom:1px solid #1e3a5c;
  display:flex;align-items:center;justify-content:space-between;
  background:#0a1e35;
}
.admin-hdr h2{font-size:15px;font-weight:600}
.admin-close{background:none;border:none;color:#7a9bb5;font-size:20px;cursor:pointer;padding:4px 8px;border-radius:6px}
.admin-close:hover{color:#f87171;background:rgba(220,38,38,0.1)}
.admin-body{overflow-y:auto;padding:20px;flex:1}
.admin-section-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:#7a9bb5;margin:0 0 12px}
.user-row{
  background:#162032;border:1px solid #1e3a5c;border-radius:10px;
  padding:12px 16px;margin-bottom:8px;
  display:flex;align-items:center;gap:12px;flex-wrap:wrap;
}
