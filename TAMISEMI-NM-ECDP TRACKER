// ══════════ EMAILJS — SINGLE ACTIVATION LINK EMAIL ══════════
// NEW FLOW: One template only. When a user registers, they receive an
// activation link directly in their own email. Clicking it approves
// their account instantly — no approve/reject emails to admin needed.

async function sendActivationEmail(user) {
  const cfg = getCfg();
  if (!cfg.publicKey || !cfg.serviceId || !cfg.tmplActivation) {
    console.warn('[EmailJS] Not configured or template ID missing.');
    return { ok:false, reason:'not_configured' };
  }
  if (typeof emailjs === 'undefined') {
    return { ok:false, reason:'library_missing' };
  }
  try {
    emailjs.init({ publicKey: cfg.publicKey });

    const baseUrl        = window.location.href.split('?')[0];
    const activateToken  = b64enc({ id:user.id, email:user.email, firstName:user.firstName, lastName:user.lastName, org:user.org, passwordHash:user.passwordHash, createdAt:user.createdAt });
    const activationLink = baseUrl + '?action=activate&tok=' + activateToken;

    const params = {
      to_email        : user.email,
      to_name         : user.firstName,
      from_name       : 'TAMISEMI NMECD Dashboard',
      reply_to        : ADMIN_EMAIL,
      subject         : 'Activate Your TAMISEMI Dashboard Account',
      user_name       : user.firstName + ' ' + user.lastName,
      user_email      : user.email,
      user_org        : user.org || '—',
      activation_link : activationLink,
      admin_email     : ADMIN_EMAIL,
      // Plain-text fallback (used if template uses {{message}})
      message         : 'Hello ' + user.firstName + ',\n\nYour account for the TAMISEMI NMECD Dashboard has been received.\n\nCopy and open this link in your browser to activate your account:\n\n' + activationLink + '\n\nTAMISEMI NMECD Programme',
      // HTML version with a clickable button (used if template uses {{html_message}})
      html_message    :
        '<div style="font-family:Arial,sans-serif;max-width:520px;margin:0 auto;padding:24px;background:#f4f4f4">' +
        '<div style="background:#16a34a;padding:18px 24px;border-radius:8px 8px 0 0">' +
        '<h2 style="color:white;margin:0;font-size:18px">TAMISEMI NMECD Dashboard</h2>' +
        '<p style="color:#dcfce7;margin:6px 0 0;font-size:12px">Early Childhood Development &middot; Tanzania Mainland</p>' +
        '</div>' +
        '<div style="background:white;padding:28px;border-radius:0 0 8px 8px;border:1px solid #e5e7eb">' +
        '<p style="font-size:15px;color:#111827;margin-top:0">Dear <strong>' + user.firstName + '</strong>,</p>' +
        '<p style="color:#374151;line-height:1.7">Your account request has been received. Click the button below to activate your account and sign in.</p>' +
        '<div style="text-align:center;margin:32px 0">' +
        '<a href="' + activationLink + '" style="background:#16a34a;color:white;padding:15px 40px;border-radius:8px;text-decoration:none;font-size:16px;font-weight:700;display:inline-block;letter-spacing:0.3px">' +
        '&#9989;&nbsp; Click Here to Activate Account' +
        '</a>' +
        '</div>' +
        '<p style="color:#6b7280;font-size:12px;line-height:1.8;background:#f9fafb;padding:12px;border-radius:6px">' +
        'After activating, sign in with:<br>' +
        '<strong>Email:</strong> ' + user.email + '<br>' +
        '<strong>Password:</strong> the password you set when registering' +
        '</p>' +
        '<hr style="border:none;border-top:1px solid #f3f4f6;margin:20px 0">' +
        '<p style="color:#9ca3af;font-size:11px;margin-bottom:0">If you did not request this, ignore this email.</p>' +
        '</div></div>',
    };

    console.log('[EmailJS] Sending activation email →', user.email);
    const resp = await emailjs.send(cfg.serviceId, cfg.tmplActivation, params, { publicKey: cfg.publicKey });
    console.log('[EmailJS] Response:', resp);
    return { ok:true, detail:'Status ' + resp.status };

  } catch(err) {
    const status = err.status || '';
    const text   = err.text || err.message || JSON.stringify(err);
    console.error('[EmailJS] Error:', err);
    const hints = {
      400:'Wrong Template ID — check field ③ in Email Setup.',
      401:'Wrong Public Key — check field ① in Email Setup.',
      403:'Wrong Service ID or service paused — check field ② in Email Setup.',
      404:'Service or Template not found — IDs must match exactly what is in your EmailJS dashboard.',
      412:'The "To Email" field in your EmailJS template must be set to {{to_email}}',
      422:'Template variable mismatch.',
      429:'Rate limit hit — wait a minute and try again.',
    };
    return { ok:false, reason:'send_failed', detail:(status?'HTTP '+status+': ':'')+text+'\n\nFix: '+(hints[status]||'Check all IDs in Email Setup.') };
  }
}

