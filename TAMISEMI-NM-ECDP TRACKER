// ══════════ HANDLE ACTIVATION LINK FROM EMAIL ══════════
// New user clicks their activation link → file.html?action=activate&tok=BASE64
// This auto-approves their account in the current browser's localStorage.
function handleURLAction() {
  const params = new URLSearchParams(window.location.search);
  const action = params.get('action');
  const tok    = params.get('tok');
  if (!action || !tok) return false;

  const data = b64dec(tok);
  if (!data || !data.id || !data.email) return false;

  const users  = DB.getUsers();
  const exists = users.findIndex(u => u.id === data.id || u.email === data.email);

  if (action === 'activate') {
    if (exists === -1) {
      // Brand new browser — add full user record as approved
      data.status     = 'approved';
      data.approvedAt = new Date().toISOString();
      users.push(data);
    } else {
      users[exists].status     = 'approved';
      users[exists].approvedAt = new Date().toISOString();
    }
    DB.saveUsers(users);
    sessionStorage.setItem('tam_action_done', 'activated:' + (data.firstName||'') + ':' + (data.email||''));
  }

  // Clean URL so link can't be reused accidentally from the address bar
  window.history.replaceState({}, '', window.location.pathname);
  return true;
}

