  const enc = new TextEncoder().encode(pw + ':tam_salt_2025');
  const buf = await crypto.subtle.digest('SHA-256', enc);
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
}

// ══════════ BASE64 encode/decode for URL tokens ══════════
function b64enc(obj) { return btoa(unescape(encodeURIComponent(JSON.stringify(obj)))); }
function b64dec(s)   { try { return JSON.parse(decodeURIComponent(escape(atob(s)))); } catch(e) { return null; } }

